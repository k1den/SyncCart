<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/llHeaderBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentTop="true"
        android:background="#99FFFFFF"
        android:padding="12dp">

        <EditText
            android:id="@+id/etCitySearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введите город"
            android:background="@android:drawable/editbox_background"
            android:padding="12dp"
            android:imeOptions="actionSearch"
            android:singleLine="true"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnFilterAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Все магазины"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnFilterSupermarket"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Супермаркеты"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnFilterConvenience"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Продукты у дома"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnFilterPharmacy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Аптеки" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llRouteInfoPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/llHeaderBlock"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        android:background="#DDFFFFFF"
        android:padding="10dp"
        android:orientation="horizontal"
        android:elevation="4dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚗 Маршрут: "
            android:textStyle="bold"
            android:textColor="@android:color/black"/>

        <TextView
            android:id="@+id/tvRouteDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 км"
            android:textColor="@android:color/black"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" • "
            android:textColor="@android:color/black"/>

        <TextView
            android:id="@+id/tvRouteTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 мин"
            android:textColor="@android:color/black"/>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnBackMap"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Назад"
        android:onClick="onBackPressed"
        android:src="@android:drawable/ic_menu_revert"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true" />

    <Button
        android:id="@+id/btnClearRoute"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#F44336"
        android:textColor="@android:color/white"
        android:text="Отменить маршрут"
        android:visibility="gone" />

</RelativeLayout>